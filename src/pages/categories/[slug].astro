---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandCard from '../../components/BrandCard.astro';
import { CATEGORIES } from '../../consts';

export async function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = CATEGORIES.find((c) => c.slug === slug)!;
const brands = (
  await getCollection('brands', ({ data }) => !data.draft && data.category === slug)
).sort((a, b) => Number(b.data.featured) - Number(a.data.featured));
---

<BaseLayout
  title={`Vegan ${cat.label} Brands`}
  description={`Discover ${brands.length} vegan and plant-based pet ${cat.label.toLowerCase()} brands. Compare ingredients, certifications, and where to buy.`}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <a href="/brands" class="text-sm text-leaf-600 hover:underline">← All categories</a>
    <h1 class="mt-3 text-4xl font-display font-extrabold text-leaf-900">
      <span class="text-5xl mr-2">{cat.emoji}</span>
      Vegan {cat.label}
    </h1>
    <p class="mt-2 text-leaf-700">{brands.length} plant-based brands in this category.</p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {brands.map((b) => <BrandCard brand={b} featured={b.data.featured} />)}
    </div>

    {brands.length === 0 && (
      <div class="mt-12 rounded-2xl border-2 border-dashed border-leaf-200 p-12 text-center">
        <div class="text-5xl">{cat.emoji}</div>
        <p class="mt-3 text-leaf-700">
          No brands listed yet. Know one?{' '}
          <a href="mailto:hello@virida.pet" class="underline text-leaf-600">Submit it →</a>
        </p>
      </div>
    )}
  </div>
</BaseLayout>
