---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrandCard from '../../components/BrandCard.astro';
import { CATEGORIES } from '../../consts';

const allBrands = (await getCollection('brands', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.name.localeCompare(b.data.name)
);
---

<BaseLayout
  title="All Vegan Pet Brands"
  description={`Browse all ${allBrands.length} vegan and plant-based pet brands in our directory. Filter by category, country, and more.`}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h1 class="text-4xl font-display font-extrabold text-leaf-900">All brands</h1>
    <p class="mt-2 text-leaf-700">{allBrands.length} vegan & plant-based pet brands worldwide.</p>

    <!-- Static category filter — JS-free, uses anchor links -->
    <div class="mt-6 flex flex-wrap gap-2">
      <a href="/brands" class="text-sm rounded-full border border-leaf-300 px-3 py-1.5 font-medium text-leaf-700 hover:bg-leaf-50">
        All
      </a>
      {CATEGORIES.map((c) => (
        <a
          href={`/categories/${c.slug}/`}
          class="text-sm rounded-full border border-leaf-200 px-3 py-1.5 font-medium text-leaf-600 hover:bg-leaf-50"
        >
          {c.emoji} {c.label}
        </a>
      ))}
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {allBrands.map((b) => <BrandCard brand={b} featured={b.data.featured} />)}
    </div>
  </div>
</BaseLayout>
