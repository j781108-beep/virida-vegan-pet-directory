---
/**
 * Privacy-friendly analytics — Plausible (no cookies, GDPR/PDPA compliant).
 *
 * To activate:
 *   1. Sign up at https://plausible.io (or self-host)
 *   2. Add your domain
 *   3. Set PUBLIC_PLAUSIBLE_DOMAIN env var (e.g. directory.virida.pet)
 *   4. Optional: PUBLIC_PLAUSIBLE_HOST if self-hosted
 *
 * Why Plausible over Google Analytics:
 *   - No cookies → no consent banner needed (Singapore PDPA / TW PDPA / EU GDPR)
 *   - 1 KB script vs ~80 KB GA = better Core Web Vitals
 *   - APAC pet parents increasingly cookie-allergic
 */
const domain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const host = import.meta.env.PUBLIC_PLAUSIBLE_HOST ?? 'https://plausible.io';
---

{domain && (
  <script
    is:inline
    defer
    data-domain={domain}
    src={`${host}/js/script.outbound-links.js`}
  />
)}
