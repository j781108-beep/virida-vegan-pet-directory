---
/**
 * Privacy-friendly analytics — Plausible (no cookies, GDPR/PDPA compliant).
 *
 * Uses Plausible's site-key snippet format. The script URL contains a unique
 * identifier for directory.virida.pet — that's why no `domain` argument is
 * needed in `plausible.init()`.
 *
 * Tracking enabled (configured in Plausible dashboard):
 *   - Page views
 *   - Outbound links  ← KEY: tracks every click to virida.pet (conversion signal)
 *   - File downloads
 *   - Form submissions
 *
 * Only loads in production builds, NOT during `npm run dev`. This keeps local
 * dev pageviews out of analytics and avoids dev-time CSP issues.
 */

const isProd = import.meta.env.PROD;
---

{
  isProd && (
    <>
      {/* Privacy-friendly analytics by Plausible */}
      <script
        is:inline
        async
        src="https://plausible.io/js/pa-GC0oalG_KDJOzZjB7Sxn0.js"
      />
      <script is:inline>window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};plausible.init();</script>
    </>
  )
}
