---
import { CATEGORIES } from '../consts';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  brand: CollectionEntry<'brands'>;
  featured?: boolean;
}
const { brand, featured } = Astro.props;
const cat = CATEGORIES.find((c) => c.slug === brand.data.category);
---

<a
  href={`/brands/${brand.id}/`}
  class:list={[
    'group block rounded-2xl border border-leaf-100 bg-white p-5 transition hover:-translate-y-0.5 hover:shadow-lg hover:border-leaf-300',
    featured && 'ring-2 ring-leaf-400 ring-offset-2 ring-offset-cream-50',
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3 min-w-0">
      {
        brand.data.logo ? (
          <Image
            src={brand.data.logo}
            alt={`${brand.data.name} logo`}
            width={56}
            height={56}
            class="size-14 rounded-xl object-cover bg-leaf-50 flex-shrink-0"
          />
        ) : (
          <div class="size-14 rounded-xl bg-leaf-100 grid place-items-center text-2xl flex-shrink-0">
            {cat?.emoji ?? '🌿'}
          </div>
        )
      }
      <div class="min-w-0">
        <h3 class="font-display font-bold text-leaf-900 truncate">{brand.data.name}</h3>
        <div class="text-xs text-leaf-600 mt-0.5">{cat?.label}</div>
      </div>
    </div>
    {
      featured && (
        <span class="text-[10px] uppercase tracking-wider font-bold bg-leaf-600 text-white px-2 py-1 rounded-full">
          Featured
        </span>
      )
    }
  </div>

  <p class="mt-3 text-sm text-leaf-700 line-clamp-2">{brand.data.tagline}</p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {
      brand.data.countries.slice(0, 4).map((c) => (
        <span class="text-[10px] font-semibold bg-leaf-50 text-leaf-700 px-2 py-1 rounded">
          {c}
        </span>
      ))
    }
    {
      brand.data.certifications.slice(0, 2).map((cert) => (
        <span class="text-[10px] font-semibold bg-cream-100 text-leaf-700 px-2 py-1 rounded">
          ✓ {cert}
        </span>
      ))
    }
  </div>
</a>
