# Copy this file to .env and fill in real values for production deployment.

# Plausible analytics (privacy-friendly, no cookies)
# Sign up at https://plausible.io, add your domain, paste it here.
PUBLIC_PLAUSIBLE_DOMAIN=directory.virida.pet

